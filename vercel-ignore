#!/bin/bash

# Vercel ignore script to exclude large files from deployment

echo "Running vercel-ignore script..."

# Remove webpack cache
rm -rf .next/cache
rm -rf .next/static/webpack

# Remove pnpm store
rm -rf .pnpm-store
rm -rf node_modules/.pnpm

# Remove MCP dependencies (not used in production)
rm -rf lib/mcp/template-creator/node_modules
rm -rf lib/mcp/template-creator/dist

# Remove development files
rm -rf examples/generated
rm -rf tests
rm -rf docs
rm -rf scripts

# Remove large dependencies that cause bundle size issues
rm -rf node_modules/tsx
rm -rf node_modules/@langchain
rm -rf node_modules/@langgraph

echo "Vercel ignore script completed."
