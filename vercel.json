{
  "functions": {
    "api/**/*": {
      "excludeFiles": [
        ".next/cache/**",
        ".pnpm-store/**"
      ]
    }
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "buildCommand": "bash scripts/vercel-build.sh",
  "installCommand": "pnpm install --frozen-lockfile",
  
}
