# Ignore development files
examples/generated
tests
docs
scripts

# Ignore MCP dependencies and serverless functions (separate deployment)
lib/mcp/template-creator/node_modules
lib/mcp/template-creator/dist
lib/mcp/template-creator/api
lib/mcp/template-creator/http-server.ts
lib/mcp/template-creator/vercel.json
lib/mcp/template-creator/.vercel
